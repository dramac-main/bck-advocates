---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Icon from '../components/Icon.astro';
---
<BaseLayout title="Page not found" noindex>
  <section class="relative isolate flex min-h-[70vh] items-center overflow-hidden bg-navy">
    <div class="absolute inset-0 -z-10 bg-grid opacity-50"></div>
    <div class="wrap py-24 text-center">
      <span class="font-display text-7xl font-semibold text-sky-light sm:text-8xl">404</span>
      <h1 class="mt-4 text-3xl font-semibold text-white sm:text-4xl">This page could not be found</h1>
      <p class="mx-auto mt-4 max-w-md text-white/75">
        The page you were looking for may have moved or no longer exists. Let’s get you back on track.
      </p>
      <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <Button href="/" variant="light" size="lg">Back to home</Button>
        <Button href="/contact/" variant="outline-light" size="lg">
          Contact us <Icon name="arrow-right" size={18} />
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
