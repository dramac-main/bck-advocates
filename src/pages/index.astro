---
import BaseLayout from '../layouts/BaseLayout.astro';
import Img from '../components/Img.astro';
import Icon from '../components/Icon.astro';
import Button from '../components/Button.astro';
import SectionHeading from '../components/SectionHeading.astro';
import TeamCard from '../components/TeamCard.astro';
import TrustStrip from '../components/TrustStrip.astro';
import StatsBand from '../components/StatsBand.astro';
import CTABand from '../components/CTABand.astro';
import { practiceAreas } from '../data/practice-areas';
import { team } from '../data/team';
import { whyChooseUs, approach, whoWeAre } from '../data/content';

const teamTeaser = team.slice(0, 3);
---
<BaseLayout title="Home">
  <!-- Hero — two-column editorial lockup -->
  <section class="relative isolate overflow-hidden bg-navy pb-16 pt-28 sm:pt-32 lg:pb-24 lg:pt-40">
    <div class="absolute inset-0 -z-10 bg-grid opacity-40"></div>
    <div class="absolute -left-40 -top-24 -z-10 h-[28rem] w-[28rem] rounded-full bg-brand/25 blur-3xl"></div>
    <div class="absolute -bottom-24 right-0 -z-10 h-80 w-80 rounded-full bg-sky/10 blur-3xl"></div>

    <div class="wrap grid items-center gap-12 lg:grid-cols-12 lg:gap-10">
      <!-- Text -->
      <div class="hero-stagger lg:col-span-7">
        <span class="inline-flex items-center gap-3 font-display text-xs font-semibold uppercase tracking-[0.2em] text-sky-light">
          <span class="brand-rule bg-sky"></span>Barnaby, Chitundu &amp; Khunga Advocates · Lusaka, Zambia
        </span>
        <h1 class="mt-5 max-w-2xl text-4xl font-semibold leading-[1.06] text-white sm:text-5xl lg:text-[3.65rem]">
          Clear advice and dependable advocacy, when it matters most.
        </h1>
        <p class="mt-6 max-w-xl text-[0.95rem] leading-relaxed text-white/85 sm:text-base lg:text-lg">
          A Lusaka firm of Advocates of the High Court and Supreme Court of Zambia and Commissioners
          for Oaths — litigation, corporate, conveyancing, employment, family, debt recovery and
          notarial services, under one roof.
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <Button href="/contact/" variant="light" size="lg">Request a Consultation</Button>
          <Button href="/practice-areas/" variant="outline-light" size="lg">Explore Practice Areas</Button>
        </div>
        <p class="mt-9 flex flex-wrap items-center gap-x-3 gap-y-1 border-t border-white/10 pt-6 text-xs text-white/55">
          <span class="font-semibold text-white/75">Advocates of the High Court &amp; Supreme Court of Zambia</span>
          <span class="text-sky/60">·</span>
          <span>Members of the Law Association of Zambia</span>
          <span class="text-sky/60">·</span>
          <span>Commissioners for Oaths</span>
        </p>
      </div>

      <!-- Image panel -->
      <div class="relative lg:col-span-5">
        <div class="relative overflow-hidden rounded-2xl shadow-lift ring-1 ring-white/15">
          <Img
            name="hero-home.jpg"
            alt="An Advocate of the High Court of Zambia in wig and gown"
            class="aspect-[4/5] w-full object-cover object-top"
            widths={[480, 720, 960]}
            sizes="(min-width: 1024px) 40vw, 90vw"
            loading="eager"
            fetchpriority="high"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-navy-deep/55 via-transparent to-transparent"></div>
        </div>
        <div class="absolute -bottom-5 -left-3 hidden rounded-xl bg-white p-5 shadow-lift sm:block lg:-left-8">
          <div class="font-display text-base font-semibold leading-tight text-navy">Advocates &amp; Commissioners<br />for Oaths</div>
          <div class="mt-1 flex items-center gap-2 text-xs text-ink/60">
            <Icon name="scales" size={15} class="text-brand-ink" /> High &amp; Supreme Court of Zambia
          </div>
        </div>
      </div>
    </div>
  </section>

  <TrustStrip />

  <!-- Who we are -->
  <section class="bg-white py-20 sm:py-24 lg:py-28">
    <div class="wrap grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div data-reveal="left" class="relative">
        <div class="overflow-hidden rounded-2xl shadow-card">
          <Img
            name="about-firm.jpg"
            alt="An advocate of Barnaby, Chitundu & Khunga Advocates at work in Lusaka"
            class="aspect-[4/3] w-full object-cover"
            widths={[500, 800, 1100]}
            sizes="(min-width: 1024px) 45vw, 90vw"
          />
        </div>
        <div class="absolute -bottom-6 -right-4 hidden rounded-xl bg-navy p-6 text-white shadow-lift sm:block">
          <div class="font-display text-2xl font-semibold text-sky-light">AHCZ · ASCZ</div>
          <div class="mt-1 text-xs uppercase tracking-wider text-white/70">Advocates of the High &amp;<br />Supreme Court of Zambia</div>
        </div>
      </div>
      <div>
        <SectionHeading eyebrow="Who we are" title={whoWeAre.heading} reveal="right" />
        <div class="mt-5 space-y-4 text-base leading-relaxed text-ink/75">
          {whoWeAre.paragraphs.map((p) => <p>{p}</p>)}
        </div>
        <figure class="mt-6 border-l-2 border-brand/50 pl-5">
          <blockquote class="font-display text-lg italic leading-relaxed text-navy">
            “{whoWeAre.callout}”
          </blockquote>
        </figure>
        <div class="mt-8">
          <Button href="/about/" variant="primary">More about the firm <Icon name="arrow-right" size={18} /></Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Practice areas — directory layout (icon-led, no photos) -->
  <section class="bg-mist py-20 sm:py-24 lg:py-28">
    <div class="wrap">
      <SectionHeading
        eyebrow="What we do"
        title="Comprehensive legal services, under one roof"
        intro="From contested litigation to conveyancing and notarial services, our advocates bring focused expertise across seven practice areas — a single, trusted partner whatever the matter."
        align="center"
      />
      <div class="mt-14 grid gap-4 sm:grid-cols-2">
        {practiceAreas.map((area) => (
          <a
            href={`/practice-areas/${area.slug}/`}
            data-reveal
            class="group flex items-start gap-5 rounded-xl border border-line bg-white p-6 shadow-card transition duration-300 hover:-translate-y-1 hover:border-brand/30 hover:shadow-lift"
          >
            <span class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-brand text-white transition-colors group-hover:bg-navy">
              <Icon name={area.icon} size={26} />
            </span>
            <span class="flex-1">
              <span class="flex items-center justify-between gap-3">
                <h3 class="font-display text-lg font-semibold text-navy">{area.shortTitle}</h3>
                <Icon name="arrow-up-right" size={18} class="shrink-0 text-brand-ink/50 transition group-hover:translate-x-0.5 group-hover:text-brand-ink" />
              </span>
              <p class="mt-1.5 text-sm leading-relaxed text-ink/70">{area.summary}</p>
            </span>
          </a>
        ))}
        <a
          href="/practice-areas/"
          data-reveal
          class="group flex items-center justify-between gap-5 rounded-xl border border-brand bg-navy p-6 text-white shadow-card transition duration-300 hover:-translate-y-1 hover:shadow-lift"
        >
          <span>
            <h3 class="font-display text-lg font-semibold text-white">View all practice areas</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-white/70">See how we advise on each discipline.</p>
          </span>
          <Icon name="arrow-right" size={22} class="shrink-0 text-sky-light transition group-hover:translate-x-1" />
        </a>
      </div>
    </div>
  </section>

  <!-- Why choose us -->
  <section class="bg-white py-20 sm:py-24 lg:py-28">
    <div class="wrap">
      <SectionHeading
        eyebrow="Why choose us"
        title="The BCK difference"
        intro="A firm that pairs the standards of the Zambian Bar with genuine care for the people and businesses we advise."
        align="center"
      />
      <div class="mt-14 grid gap-8 reveal-stagger sm:grid-cols-2 lg:grid-cols-3">
        {whyChooseUs.map((f) => (
          <div data-reveal class="flex flex-col rounded-2xl border border-line bg-white p-7 shadow-card transition hover:-translate-y-1 hover:shadow-lift">
            <span class="inline-flex h-14 w-14 items-center justify-center rounded-xl bg-brand text-white">
              <Icon name={f.icon} size={28} />
            </span>
            <h3 class="mt-5 text-lg font-semibold text-navy">{f.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink/70">{f.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Approach — horizontal stepper -->
  <section class="bg-mist py-20 sm:py-24 lg:py-28">
    <div class="wrap">
      <SectionHeading
        eyebrow="How we work"
        title="A clear, five-step approach"
        intro="We work closely with you from the first conversation to the final resolution — understanding the matter, advising candidly and acting with diligence."
        align="center"
      />
      <ol class="relative mt-16 grid gap-y-10 sm:grid-cols-2 lg:grid-cols-5 lg:gap-x-6 reveal-stagger">
        <div class="absolute left-0 right-0 top-7 hidden h-px bg-brand/20 lg:block" aria-hidden="true"></div>
        {approach.map((s) => (
          <li data-reveal class="relative text-center lg:text-left">
            <div class="relative z-10 mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-brand font-display text-lg font-bold text-white ring-4 ring-mist lg:mx-0">
              {s.n}
            </div>
            <h3 class="mt-5 text-base font-semibold text-navy">{s.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink/70">{s.text}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <StatsBand />

  <!-- Team teaser -->
  <section class="bg-white py-20 sm:py-24 lg:py-28">
    <div class="wrap">
      <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
        <SectionHeading
          eyebrow="Our team"
          title="The advocates behind the practice"
          intro="Partners and practitioners committed to careful, dependable work — and to keeping you informed at every stage."
          class="md:max-w-2xl"
        />
        <div class="hidden shrink-0 md:block">
          <Button href="/team/" variant="outline">
            Meet the team <Icon name="arrow-right" size={18} class="transition-transform group-hover:translate-x-1" />
          </Button>
        </div>
      </div>
      <div class="mt-12 grid gap-6 reveal-stagger sm:grid-cols-2 lg:grid-cols-3">
        {teamTeaser.map((member) => <TeamCard member={member} />)}
      </div>
      <div class="mt-10 md:hidden">
        <Button href="/team/" variant="outline" class="w-full">
          Meet the team <Icon name="arrow-right" size={18} />
        </Button>
      </div>
    </div>
  </section>

  <CTABand />
</BaseLayout>
