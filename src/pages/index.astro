---
import BaseLayout from '../layouts/BaseLayout.astro';
import Img from '../components/Img.astro';
import Icon from '../components/Icon.astro';
import Button from '../components/Button.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PracticeAreaCard from '../components/PracticeAreaCard.astro';
import TeamCard from '../components/TeamCard.astro';
import TrustStrip from '../components/TrustStrip.astro';
import StatsBand from '../components/StatsBand.astro';
import CTABand from '../components/CTABand.astro';
import { practiceAreas } from '../data/practice-areas';
import { team } from '../data/team';
import { whyChooseUs, approach, whoWeAre } from '../data/content';

const teamTeaser = team.slice(0, 3);
---
<BaseLayout title="Home">
  <!-- Hero -->
  <section class="sticky top-0 z-0 flex min-h-[100svh] items-center overflow-hidden bg-navy">
    <div class="absolute inset-0 -z-10">
      <Img
        name="hero-home.jpg"
        alt=""
        class="hero-kenburns h-full w-full object-cover"
        widths={[768, 1280, 1920, 2400]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-navy via-navy/85 to-navy/30"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-navy-deep/80 via-transparent to-transparent"></div>
    </div>

    <div class="wrap hero-stagger py-24 sm:py-28">
      <span class="mb-5 inline-flex items-center gap-3 font-display text-xs font-semibold uppercase tracking-[0.22em] text-sky-light">
        <span class="brand-rule bg-sky"></span>Barnaby, Chitundu &amp; Khunga Advocates — Lusaka, Zambia
      </span>
      <h1 class="max-w-4xl text-4xl font-semibold leading-[1.08] text-white sm:text-6xl lg:text-7xl">
        <span class="sr-only">Trusted legal counsel for your business, property, family and future.</span>
        <span aria-hidden="true">
          Trusted legal counsel<br />
          for your <span class="word-rotator text-sky-light"><span class="word-rotator__word">business</span></span>
        </span>
      </h1>
      <p class="mt-6 max-w-xl text-[0.95rem] leading-relaxed text-white/85 sm:text-base lg:text-lg">
        A Lusaka firm of advocates delivering clear, dependable counsel — litigation, corporate,
        conveyancing, employment, family, debt recovery and notarial services, under one roof.
      </p>
      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <Button href="/contact/" variant="light" size="lg">Request a Consultation</Button>
        <Button href="/practice-areas/" variant="outline-light" size="lg">Explore Practice Areas</Button>
      </div>
    </div>

    <a href="#intro" class="scroll-cue" aria-label="Scroll to content">
      <span class="mouse"><span class="wheel"></span></span>
      <span class="text-[0.6rem] font-semibold uppercase tracking-[0.25em]">Scroll</span>
    </a>
  </section>

  <!-- Everything below scrolls up over the pinned hero -->
  <div class="relative z-10">
    <TrustStrip />

    <!-- Who we are -->
    <section id="intro" class="scroll-mt-24 bg-white py-20 sm:py-24 lg:py-28">
      <div class="wrap grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
        <div data-reveal="left" class="relative">
          <div class="overflow-hidden rounded-2xl shadow-card">
            <Img
              name="about-firm.jpg"
              alt="Barnaby, Chitundu & Khunga Advocates — a Lusaka law firm"
              class="aspect-[4/3] w-full object-cover"
              widths={[500, 800, 1100]}
              sizes="(min-width: 1024px) 45vw, 90vw"
            />
          </div>
          <div class="absolute -bottom-6 -right-4 hidden rounded-xl bg-navy p-6 text-white shadow-lift sm:block">
            <div class="font-display text-2xl font-semibold text-sky-light">AHCZ · ASCZ</div>
            <div class="mt-1 text-xs uppercase tracking-wider text-white/70">Advocates of the High &amp;<br />Supreme Court of Zambia</div>
          </div>
        </div>
        <div>
          <SectionHeading eyebrow="Who we are" title={whoWeAre.heading} reveal="right" />
          <div class="mt-5 space-y-4 text-base leading-relaxed text-ink/75">
            {whoWeAre.paragraphs.map((p) => <p>{p}</p>)}
          </div>
          <figure class="mt-6 border-l-2 border-brand/50 pl-5">
            <blockquote class="font-display text-lg italic leading-relaxed text-navy">
              “{whoWeAre.callout}”
            </blockquote>
          </figure>
          <div class="mt-8">
            <Button href="/about/" variant="primary">More about the firm <Icon name="arrow-right" size={18} /></Button>
          </div>
        </div>
      </div>
    </section>

    <!-- Practice areas -->
    <section class="bg-mist py-20 sm:py-24 lg:py-28">
      <div class="wrap">
        <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
          <SectionHeading
            eyebrow="What we do"
            title="Comprehensive legal services, under one roof"
            intro="From contested litigation to conveyancing and notarial services, our advocates bring focused expertise across seven practice areas — so you have a single, trusted partner whatever the matter."
            class="md:max-w-2xl"
          />
          <div class="hidden shrink-0 md:block">
            <Button href="/practice-areas/" variant="outline">
              All practice areas <Icon name="arrow-right" size={18} class="transition-transform group-hover:translate-x-1" />
            </Button>
          </div>
        </div>

        <div class="mt-12 grid gap-6 reveal-stagger sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {practiceAreas.map((area) => <PracticeAreaCard area={area} />)}
        </div>
      </div>
    </section>

    <!-- Why choose us -->
    <section class="bg-white py-20 sm:py-24 lg:py-28">
      <div class="wrap">
        <SectionHeading
          eyebrow="Why choose us"
          title="The BCK difference"
          intro="A firm that pairs the standards of the Zambian Bar with genuine care for the people and businesses we advise."
          align="center"
        />
        <div class="mt-14 grid gap-8 reveal-stagger sm:grid-cols-2 lg:grid-cols-3">
          {whyChooseUs.map((f) => (
            <div data-reveal class="flex flex-col rounded-2xl border border-line bg-white p-7 shadow-card transition hover:-translate-y-1 hover:shadow-lift">
              <span class="inline-flex h-14 w-14 items-center justify-center rounded-xl bg-brand text-white">
                <Icon name={f.icon} size={28} />
              </span>
              <h3 class="mt-5 text-lg font-semibold text-navy">{f.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-ink/70">{f.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Stats -->
    <StatsBand />

    <!-- Approach — sticky scrollytelling -->
    <section class="relative bg-navy py-20 sm:py-24 lg:py-28">
      <div class="absolute inset-0 -z-10 overflow-hidden bg-grid opacity-50"></div>
      <div class="wrap lg:grid lg:grid-cols-2 lg:gap-16">
        <div class="lg:sticky lg:top-28 lg:h-fit lg:self-start lg:py-4">
          <SectionHeading
            eyebrow="Our approach"
            title="A clear, client-centred way of working"
            intro="We work closely with you from the first conversation to the final resolution — understanding the matter, advising candidly and acting with diligence."
            dark
          />
        </div>
        <ol class="mt-12 space-y-6 lg:mt-0 lg:space-y-20">
          {approach.map((s) => (
            <li data-reveal="right" class="relative rounded-2xl border border-white/10 bg-white/5 p-7 sm:p-8">
              <div class="font-display text-5xl font-semibold text-sky-light/90">{s.n}</div>
              <h3 class="mt-4 text-xl font-semibold text-white">{s.title}</h3>
              <p class="mt-2 leading-relaxed text-white/70">{s.text}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- Team teaser -->
    <section class="bg-white py-20 sm:py-24 lg:py-28">
      <div class="wrap">
        <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
          <SectionHeading
            eyebrow="Our team"
            title="The advocates behind the practice"
            intro="Partners and practitioners committed to careful, dependable work — and to keeping you informed at every stage."
            class="md:max-w-2xl"
          />
          <div class="hidden shrink-0 md:block">
            <Button href="/team/" variant="outline">
              Meet the team <Icon name="arrow-right" size={18} class="transition-transform group-hover:translate-x-1" />
            </Button>
          </div>
        </div>
        <div class="mt-12 grid gap-6 reveal-stagger sm:grid-cols-2 lg:grid-cols-3">
          {teamTeaser.map((member) => <TeamCard member={member} />)}
        </div>
        <div class="mt-10 md:hidden">
          <Button href="/team/" variant="outline" class="w-full">
            Meet the team <Icon name="arrow-right" size={18} />
          </Button>
        </div>
      </div>
    </section>

    <CTABand />
  </div>
</BaseLayout>

<script>
  // Hero word rotator — cycles the highlighted word
  const word = document.querySelector('.word-rotator__word');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (word && !reduce) {
    const words = ['business', 'property', 'family', 'future'];
    let i = 0;
    setInterval(() => {
      i = (i + 1) % words.length;
      word.classList.add('is-out');
      setTimeout(() => {
        word.textContent = words[i];
        word.classList.add('is-in');
        word.classList.remove('is-out');
        requestAnimationFrame(() => requestAnimationFrame(() => word.classList.remove('is-in')));
      }, 360);
    }, 2600);
  }
</script>
