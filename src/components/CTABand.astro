---
import Button from './Button.astro';
import Icon from './Icon.astro';
import { whatsappLink } from '../data/site';

interface Props {
  title?: string;
  text?: string;
}
const {
  title = 'Ready to discuss your legal matter?',
  text = "Tell us what you're facing and we'll arrange a consultation with the right practitioner — clear advice, sensible next steps and complete confidence.",
} = Astro.props;
---
<section class="relative isolate overflow-hidden bg-navy">
  <div class="absolute inset-0 -z-10 bg-grid opacity-60"></div>
  <div class="absolute -right-20 -top-20 -z-10 h-56 w-56 rounded-full bg-sky/15 blur-3xl"></div>
  <div class="wrap flex flex-col items-start gap-8 py-14 lg:flex-row lg:items-center lg:justify-between lg:py-16">
    <div class="max-w-2xl">
      <span class="mb-3 inline-flex items-center gap-3 font-display text-xs font-semibold uppercase tracking-[0.2em] text-sky-light">
        <span class="brand-rule bg-sky"></span>Let's talk
      </span>
      <h2 class="text-3xl font-semibold text-white sm:text-4xl">{title}</h2>
      <p class="mt-3 text-white/75">{text}</p>
    </div>
    <div class="flex w-full flex-col gap-3 sm:flex-row lg:w-auto lg:flex-col xl:flex-row">
      <Button href="/contact/" variant="light" size="lg">Request a Consultation</Button>
      <Button href={whatsappLink()} variant="whatsapp" size="lg" target="_blank">
        <Icon name="whatsapp" size={20} /> WhatsApp Us
      </Button>
    </div>
  </div>
</section>
