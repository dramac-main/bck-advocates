  plus: '<path d="M12 5v14M5 12h14"/>',
  quote: '<path d="M6 7h4v4c0 2.2-1.3 3.6-3.5 4M14 7h4v4c0 2.2-1.3 3.6-3.5 4"/>',

  // --- Social / brand (filled) ---
  whatsapp: '<path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 1.8c2.16 0 4.19.84 5.72 2.37a8.06 8.06 0 0 1 2.37 5.72c0 4.46-3.63 8.09-8.1 8.09a8.1 8.1 0 0 1-4.13-1.13l-.3-.18-3.12.82.83-3.04-.19-.31a8.03 8.03 0 0 1-1.24-4.3c0-4.46 3.63-8.09 8.1-8.09Zm-3.2 4.36c-.15 0-.4.06-.6.28-.21.22-.8.78-.8 1.9 0 1.12.82 2.2.93 2.35.11.15 1.6 2.55 3.95 3.48 1.84.73 2.22.59 2.62.55.4-.03 1.3-.53 1.49-1.05.18-.51.18-.95.13-1.04-.06-.09-.2-.15-.43-.26-.22-.11-1.36-.68-1.57-.75-.21-.08-.37-.11-.52.11-.15.22-.59.75-.72.9-.13.15-.27.17-.5.06-.23-.11-.97-.36-1.85-1.14-.68-.61-1.14-1.36-1.28-1.59-.13-.22-.01-.34.1-.45.1-.1.22-.27.34-.4.11-.14.15-.23.22-.38.08-.15.04-.28-.02-.4-.06-.11-.52-1.26-.71-1.72-.19-.45-.38-.39-.52-.4h-.45Z"/>',
