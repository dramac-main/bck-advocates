  // --- UI icons ---
  'arrow-right': '<path d="M4 12h16M14 6l6 6-6 6"/>',
  'arrow-up-right': '<path d="M7 17 17 7M9 7h8v8"/>',
  'chevron-right': '<path d="m9 6 6 6-6 6"/>',
  phone: '<path d="M6.3 3h3l1.5 5-2 1.4a12 12 0 0 0 5.8 5.8l1.4-2 5 1.5v3a2 2 0 0 1-2 2A17 17 0 0 1 4.3 5a2 2 0 0 1 2-2z"/>',
