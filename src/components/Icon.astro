  briefcase: '<rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><path d="M3 13h18"/>',
  shield: '<path d="M12 3 5 6v5c0 4.4 3 8.3 7 9.5 4-1.2 7-5.1 7-9.5V6l-7-3z"/><path d="m9 12 2 2 4-4"/>',
  handshake: '<path d="m11 17 2 2a1.4 1.4 0 0 0 2-2l-.5-.5 1 1a1.4 1.4 0 0 0 2-2l-4-4 1-1a2 2 0 0 0-2.8 0L11 10 8 7H4l-1 7 3 3M14 13l-2-2"/>',
