---
/** Inline SVG icon set (practice + value + UI + social). Decorative by default. */
interface Props {
  name: string;
  class?: string;
  size?: number;
}
const { name, class: className = '', size = 24 } = Astro.props;

// Stroke-based line icons (vs. filled brand glyphs)
const strokeIcons = new Set([
  'scales', 'gavel', 'litigation', 'corporate', 'conveyancing', 'employment',
  'family', 'debt', 'oaths', 'award', 'target', 'lightbulb', 'document',
  'briefcase', 'shield', 'handshake', 'clock', 'lock', 'users',
  'arrow-right', 'arrow-up-right', 'chevron-right', 'phone', 'mail', 'location',
  'check', 'menu', 'close', 'plus', 'quote', 'instagram',
]);

const paths: Record<string, string> = {
  // --- Practice-area icons ---
  scales: '<path d="M12 3.8v16.7"/><path d="M7.5 20.5h9"/><path d="M4 7.5h16"/><path d="M4 7.5 1.7 13a2.3 2.3 0 0 0 4.6 0L4 7.5Z"/><path d="M20 7.5 17.7 13a2.3 2.3 0 0 0 4.6 0L20 7.5Z"/><circle cx="12" cy="3" r="1"/>',
  litigation: '<path d="m14.5 12.5-8 8a2.12 2.12 0 1 1-3-3l8-8"/><path d="m16 16 6-6"/><path d="m8 8 6-6"/><path d="m9 7 8 8"/><path d="m21 11-8-8"/>',
