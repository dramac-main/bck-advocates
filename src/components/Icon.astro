  conveyancing: '<path d="m3 10 9-7 9 7"/><path d="M5 9.2V20a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V9.2"/><path d="M9.5 21v-6h5v6"/>',
  employment: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  family: '<circle cx="8.5" cy="8" r="3"/><circle cx="17" cy="9" r="2.4"/><path d="M2.5 21v-1a5 5 0 0 1 5-5h2a5 5 0 0 1 5 5v1"/><path d="M15.5 21v-1a4 4 0 0 1 4-4 3 3 0 0 1 3 3v2"/>',
  debt: '<rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2.6"/><path d="M6 9.5v5M18 9.5v5"/>',
  oaths: '<rect x="5" y="18.5" width="14" height="2.5" rx="1.2"/><path d="M9 18.5v-2.2a3 3 0 0 1-3-3V10a3 3 0 0 1 3-3h6a3 3 0 0 1 3 3v3.3a3 3 0 0 1-3 3v2.2"/>',

  // --- Value / differentiator icons ---
  award: '<circle cx="12" cy="8" r="6"/><path d="M15.5 12.9 17 22l-5-3-5 3 1.5-9.1"/>',
