---
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { site, fullAddress, whatsappLink } from '../data/site';
import { practiceAreas } from '../data/practice-areas';

const year = new Date().getFullYear();

const socials = [
  { name: 'Facebook', href: site.socials.facebook, icon: 'facebook' },
  { name: 'LinkedIn', href: site.socials.linkedin, icon: 'linkedin' },
  { name: 'Instagram', href: site.socials.instagram, icon: 'instagram' },
].filter((s) => s.href);

const company = [
  { label: 'About Us', href: '/about/' },
  { label: 'Practice Areas', href: '/practice-areas/' },
  { label: 'Our Team', href: '/team/' },
  { label: 'Contact', href: '/contact/' },
];
---
<footer class="bg-navy-deep text-white/70">
  <div class="wrap grid gap-10 py-14 sm:grid-cols-2 lg:grid-cols-12 lg:gap-8 lg:py-16">
    <!-- Brand -->
    <div class="lg:col-span-4">
      <Logo variant="light" class="h-11 text-[1.25rem]" />
      <p class="mt-5 max-w-xs text-sm italic leading-relaxed text-white/60">
        “{site.promise}”
      </p>
      <p class="mt-4 max-w-xs text-sm leading-relaxed">
        A Lusaka firm of Advocates of the High Court and Supreme Court of Zambia and Commissioners
        for Oaths — clear, dependable counsel for businesses, institutions and individuals.
      </p>
      {socials.length > 0 && (
        <div class="mt-6 flex gap-3">
          {socials.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.name}
              class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/15 text-white/80 transition hover:border-sky hover:text-sky-light"
            >
              <Icon name={s.icon} size={18} />
            </a>
          ))}
        </div>
      )}
    </div>

    <!-- Practice areas -->
    <div class="lg:col-span-4">
      <h2 class="font-display text-sm font-semibold uppercase tracking-[0.18em] text-white">Practice Areas</h2>
      <ul class="mt-5 grid gap-x-6 gap-y-1 text-sm sm:grid-cols-2">
        {practiceAreas.map((a) => (
          <li>
            <a href={`/practice-areas/${a.slug}/`} class="inline-block py-1 transition-colors hover:text-sky-light">{a.shortTitle}</a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Company -->
    <div class="lg:col-span-2">
      <h2 class="font-display text-sm font-semibold uppercase tracking-[0.18em] text-white">Firm</h2>
      <ul class="mt-5 space-y-1 text-sm">
        {company.map((c) => (
          <li><a href={c.href} class="inline-block py-1 transition-colors hover:text-sky-light">{c.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Contact -->
    <div class="lg:col-span-2">
      <h2 class="font-display text-sm font-semibold uppercase tracking-[0.18em] text-white">Get in touch</h2>
      <ul class="mt-5 space-y-4 text-sm">
        <li class="flex gap-3">
          <Icon name="location" size={18} class="mt-0.5 shrink-0 text-sky-light" />
          <span>{fullAddress()}</span>
        </li>
        <li class="flex gap-3">
          <Icon name="phone" size={18} class="mt-0.5 shrink-0 text-sky-light" />
          <span class="flex flex-col">
            <a href={site.contact.phoneHref} class="hover:text-sky-light">{site.contact.phone}</a>
            <a href={site.contact.mobileHref} class="hover:text-sky-light">{site.contact.mobile}</a>
          </span>
        </li>
        <li class="flex gap-3">
          <Icon name="mail" size={18} class="mt-0.5 shrink-0 text-sky-light" />
          <a href={`mailto:${site.contact.email}`} class="break-all hover:text-sky-light">{site.contact.email}</a>
        </li>
        <li class="flex gap-3">
          <Icon name="whatsapp" size={18} class="mt-0.5 shrink-0 text-sky-light" />
          <a href={whatsappLink()} target="_blank" rel="noopener noreferrer" class="hover:text-sky-light">Chat on WhatsApp</a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="wrap flex flex-col gap-2 py-6 text-xs text-white/50 sm:flex-row sm:items-center sm:justify-between">
      <div class="space-y-1">
        <p>&copy; {year} {site.name}. All rights reserved.</p>
        <p>
          Designed &amp; built by
          <a
            href="https://wa.me/260770569012"
            target="_blank"
            rel="noopener noreferrer"
            class="font-medium text-white/75 transition-colors hover:text-sky-light"
          >Dramac Marketing Agency</a>
        </p>
      </div>
      <p class="flex flex-wrap gap-x-4 gap-y-1">
        <span>{site.registration.courts}</span>
        <span>{site.registration.laz}</span>
        <span>{site.registration.oaths}</span>
      </p>
    </div>
  </div>
</footer>
