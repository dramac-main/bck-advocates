---
import Icon from './Icon.astro';

/** A slim band of trust signals drawn from the firm's credentials. */
const items: { icon: string; label: string }[] = [
  { icon: 'scales', label: 'Advocates of the High Court & Supreme Court of Zambia' },
  { icon: 'shield', label: 'Members of the Law Association of Zambia' },
  { icon: 'oaths', label: 'Commissioners for Oaths' },
  { icon: 'location', label: 'Burma Residential Area, Lusaka' },
];
---
<section class="border-y border-line bg-cloud">
  <div class="wrap grid grid-cols-1 gap-x-8 gap-y-5 py-7 sm:grid-cols-2 lg:grid-cols-4">
    {items.map((it) => (
      <div class="flex items-center gap-3">
        <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand/10 text-brand-ink">
          <Icon name={it.icon} size={20} />
        </span>
        <span class="font-display text-sm font-semibold leading-snug text-navy">{it.label}</span>
      </div>
    ))}
  </div>
</section>
